<%= form_with(model: collection, id: dom_id(collection), url: collections_path) do |form| %>
  <%= render "shared/form_messages", resource: collection, message: local_assigns[:message] %>

  <div class="flex">
    <div class="flex-1 min-w-0">
      <label for="group" class="block text-sm font-medium text-gray-700 pt-2">Add New Collection</label>

      <div class="flex py-2">
        <div class="flex-1"><%= form.text_field :name, autocomplete: "off", class: "form-text-field" %></div>
        <div class="flex justify-end"><%= form.submit "Add", class: "btn-primary ml-2 " %></div>
      </div>
    </div>
  </div>
<% end %>
