<main class="w-full mx-auto space-y-3 py-4">
  <% frame_id = dom_id(@about, "address_turbo_frame") %>

  <%= turbo_frame_tag frame_id, class: "initial" do %>
    <%= form_with(model: @about, id: dom_id(@about), url: contact_about_path(@contact, @about), data: { turbo_frame: frame_id }) do |form| %>
      <main class="w-full mx-auto space-y-3 py-4">
        <div>
          <label for="date" class="text-sm font-normal text-gray-500"> Address</label>
          <%= form.text_area :address, class: "form-text-field h-20 mt-1" %>
        </div>

        <div class="flex justify-end space-x-2">
          <%= form.button "Save", class: "btn-primary" %>
          <%= link_to "Cancel", contact_about_index_path(@contact), class: "ml-3 btn-secondary " %>
        </div>
      </main>
    <% end %>
  <% end %>

