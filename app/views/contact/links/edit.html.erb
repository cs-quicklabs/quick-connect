<%= turbo_frame_tag dom_id(@link) do %>
  <%= form_with(model: @link, id: dom_id(@link), url: contact_social_path(@contact)) do |form| %>
    <main class="max-w-lg px-4 pt-6 pb-12 mx-auto space-y-6 lg:pb-8">
      <%= render "shared/form_messages", resource: @link, message: local_assigns[:message] %>

      <div>
        <label for="date" class="text-sm font-normal text-gray-500">
          Edit <%= @link.link_type.split("-").last.upcase_first %> Link
        </label>

        <%= form.text_field :link, class: "form-text-field mt-1" %>
        <%= form.text_field :user_id, value: current_user.id, class: "hidden" %>
      </div>

      <div class="flex justify-end space-x-2">
        <%= form.button "Save", class: "btn-primary" %>
        <%= link_to "Cancel", contact_about_index_path(@contact), class: "ml-3 btn-secondary " %>
      </div>
    </main>
  <% end %>
<% end %>
